{
    auto_https off
}

:80 {
    # Enable response compression at the edge.
    encode gzip zstd

    # Route API traffic to the Go LLM service.
    @api path /api/*
    reverse_proxy @api llm-server:8081 {
        # Overwrite forwarded headers so upstream sees real client metadata.
        header_up X-Forwarded-For {http.request.remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }

    # Cache static assets aggressively.
    @static path /assets/* /favicon.ico /robots.txt
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Route everything else to the Svelte/Vite app service.
    reverse_proxy app:5173
}